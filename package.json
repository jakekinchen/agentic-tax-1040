{
  "name": "agentic-tax-1040",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic synthetic 2025 Form 1040 assistant.",
  "type": "module",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/unit tests/integration",
    "test:pdf": "vitest run tests/integration/pdf.test.ts",
    "test:e2e": "playwright test",
    "eval": "tsx evals/run.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm eval && pnpm build",
    "assets:fetch": "tsx scripts/fetch-irs-assets.ts",
    "assets:verify": "tsx scripts/verify-irs-assets.ts",
    "assets:inspect-fields": "tsx scripts/inspect-1040-fields.ts",
    "assets:tax-table": "tsx scripts/extract-tax-table.ts",
    "fixtures:sample": "tsx scripts/generate-sample-w2.ts",
    "smoke:live": "tsx scripts/smoke-live.ts"
  },
  "keywords": [
    "tax",
    "openai",
    "agents",
    "pdf"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "11.0.0",
    "@fastify/static": "9.1.3",
    "@openai/agents": "0.12.0",
    "@pdf-lib/fontkit": "1.1.1",
    "fastify": "5.8.5",
    "file-type": "22.0.1",
    "nanoid": "5.1.16",
    "openai": "6.44.0",
    "pdf-lib": "1.17.1",
    "pino": "10.3.1",
    "zod": "4.1.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
